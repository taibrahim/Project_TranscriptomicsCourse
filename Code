#generate custom correlation plot
correlation_to_ggplot = function(data_frame, row, column,correlation, p_value){
    ggplot(data_frame, aes_string(x= row, y = column)) +
    geom_point( size=2) +
    ggtitle(paste("corr = ",round(x=correlation,5),"   p-value = ",signif(x= p_value,5))) +
    theme_bw() +
    theme(plot.title = element_text(colour = if(p_value <= 0.001) "red" else "black")) %>% return()
}
#returns the correlation of a list of variables as a function of another list of variables, 
#return a grid of ggplot
correlation_data_frame_result_funtion = function(selection1, selection2, data_frame){
    ggplot_list = vector(mode = 'list', length = length(selection2))    
    ggcount = 1
    for(row in selection1){
        for(column in selection2){
            if(row != column){
                correlation_result = cor(data_frame[,row],data_frame[,column])
                correlation_p_value = cor.test(data_frame[,row],data_frame[,column])$p.value
                ggplot_list[[ggcount]] <- correlation_to_ggplot(data_frame[c(row, column)], 
                                                                row, column, correlation_result, correlation_p_value)
                ggcount = ggcount +1
            }
        }
    }
    grid_plot <<- cowplot::plot_grid(plotlist = ggplot_list, nrow = GGPLOT_GRID_ROW_NUMBER , ncol = GGPLOT_GRID_COL_NUMBER)
    return(grid_plot)
}

