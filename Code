#compute -log10(p_value) + log10_default_pValue (if == 0 : p-value equals 0.05, if >0 : significant, other: non significant)
#correlations for numerical variable of the clinical data set as a function of the clusters counts
clinical_numerical_morphological_correlation_plot_matrix = function(clinical_variables_name){    
    p_value_data_frame = data.frame(row.names = colnames(morphological_counts))
    for (cluster in colnames(morphological_counts)){
        for(clinical_variables in clinical_variables_name){
            p_value = cor.test(clinical_morphological[,clinical_variables], clinical_morphological[,cluster])$p.value
            p_value_data_frame[cluster, clinical_variables] = -log10(p_value) + log10_default_pValue
        }
    }
    return(p_value_data_frame)
}

