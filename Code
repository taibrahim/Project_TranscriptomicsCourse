clinical_wilcox_krustal_plot_matrix = function(clinical_variables_name){
    p_value_data_frame = data.frame(row.names = colnames(morphological_counts))
    for(clinical in clinical_variables_name){
        for(cluster in colnames(morphological_counts)){
            wilcox_krustal_param_vector = vector('list', length = 2)
            count_wilcox_krustal_param = 1
            #iterates through all levels of a factor variable in a manner similar to
            #the wilcox_or_kruskal_data_frame_to_result_list function
            for(level in levels(categorial_morphological[,clinical])){
                wilcox_krustal_param_vector[[count_wilcox_krustal_param]] = 
                categorial_morphological[categorial_morphological[,clinical] == level,cluster]
                count_wilcox_krustal_param = count_wilcox_krustal_param +1 
            }
            categorial_morphological_p_value = compute_wilcox_or_kruskal(wilcox_krustal_param_vector)$p.value
            p_value_data_frame[cluster, clinical] = -log10(categorial_morphological_p_value) + log10_default_pValue
        }
    }
    return(p_value_data_frame)
}

