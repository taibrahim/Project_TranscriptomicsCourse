#compute a kruskal or wilcoxon test based on the number of factor levels (ex: DTHHRDY => 5 levels => kruskal)
compute_wilcox_or_kruskal = function(values_vectors){
    if(length(values_vectors) == 2 && (class(values_vectors[[1]]) != 'factor')){
        return((wilcox.test(values_vectors[[1]], values_vectors[[2]])))
    }
    else{
        return((kruskal.test(values_vectors)))
    }
}

#returns a leveling of a factorial variable or not
levels_not_factor = function(x){
    return(if(class(x) == 'factor') levels(x) else levels(as.factor(x)))
}
           
#generate custom kruskal or wilcoxon plot
wilcox_kruskal_wilcox_ggplot <- function(x_name, y_name, p_value, data_frame){
    ggplot(data_frame, aes_string(x = x_name, y = y_name)) + 
        geom_boxplot(aes_string(color = x_name)) +
        ggtitle(paste("p-value : ", p_value)) +
        theme(plot.title = element_text(colour = if(p_value <= 0.001) "red" else "black"))
}

#Allows to transform the result of kruskal or wilcoxon into a sentence. This will allow for nice display in the latex pdf. 
wilcox_or_kruskal_result_to_string = function(result){
    return(textGrob(mgsub::mgsub(paste(capture.output(print(result)), collapse = ""),c(",",":"),c(",\n",":\n"))))
}                               
#returns the tests (kruskal/wilcoxon) of a list of variables as a function of another list of variables, 
#the return is a list of the result of the test followed by the plot at the next index.
wilcox_or_kruskal_data_frame_to_result_list<-function(selection1, selection2, data_frame){
    ggplot_list = vector(mode = 'list', length = length(selection2)*2)
    ggcount = 1
    for(row in selection1){
        for(column in selection2){
            if(row != column){
                wilcox_kruskal_vector = vector('list', length = 2)
                count_wilcox_kruskal_param = 1
                #Creation of a vector for each level of the current factor variable. If the level match with an id 
                #(ex: id1 is of Postmortem death), the value of the second variable will be added to the vector. 
                #This set of vectors is used for the calculation of the test.
                for(level in levels_not_factor(data_frame[,row])){
                    wilcox_kruskal_vector[[count_wilcox_kruskal_param]] = data_frame[data_frame[,row]==level,column]
                    count_wilcox_kruskal_param = count_wilcox_kruskal_param +1 
                }
                wilcox_or_kruskal_result = compute_wilcox_or_kruskal(wilcox_kruskal_vector)
                ggplot_list[[ggcount]] = wilcox_or_kruskal_result_to_string(wilcox_or_kruskal_result)
                ggplot_list[[ggcount+1]] = wilcox_kruskal_wilcox_ggplot(row, column, wilcox_or_kruskal_result$p.value,
                                                               data_frame[c(row, column)])
                ggcount = ggcount +2
            }
        }
    }
    return(ggplot_list)
}


