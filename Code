#Allows you to correctly fill in the data.fame mentioned above from a DESeq2 result.
store_in_clinical_cluster_confounded = function(res, confounder){
    clinical_cluster_confounded[confounder] <<- FALSE
    for(cluster in rownames(res)){
        clinical_cluster_confounded[cluster, confounder] <<- TRUE
    }
}


#print and plot the DESeq2 results for the 64 clusters based on a clinical variable. The results are filtered to keep only the 
#significant ones (<0.05). is_more_than_two_factorial is used in particular for DTHHRDY which requires a  different calculation.
DESeq_plot_from_matrix <- function(design_, x_, intgroup_, is_more_than_two_factorial = FALSE){
    dds <- suppressMessages(DESeqDataSetFromMatrix(
        countData = translated_morphological_counts, colData = clinical_data, design = design_))
    dds <- suppressMessages(if(is_more_than_two_factorial) DESeq(dds, test = "LRT", reduced = ~1) else DESeq(dds))
    res <- results(dds)
    res <- na.omit(res)
    res <- res[res$padj <= 0.05,]
    res <- res[order(res$padj),]

    fwrite(as.data.frame(res), paste("Q2.1_DESeq2_", toString(design_), ".csv"), row.names = T)
    print(data.frame(row.names = rownames(res),"log2FoldChange" = res$log2FoldChange,  "padj" = res$padj) %>% head())
    #extract the best cluster number from the structure of DESeq2 results
