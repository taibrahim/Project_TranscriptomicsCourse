BMI_to_category <- function(BMI) {
  if (BMI < 18.5){BMI_category = "underweight"}
  else if (BMI < 25){BMI_category = "normal"}
  else if (BMI < 30){BMI_category = "overweight"}
  else{BMI_category = "obesity"}
  return(BMI_category)
}

